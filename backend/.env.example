# Backend Environment Configuration
# Copy this file to .env for local development

# Database Mode
# - mock: Sử dụng file-based mock database (cho local development)
# - dynamodb: Kết nối tới DynamoDB thật (cho testing hoặc production)
DB_MODE=mock

# AWS Configuration (chỉ cần khi DB_MODE=dynamodb)
AWS_REGION=ap-southeast-1
DYNAMODB_TABLE_NAME=EventApp-Data
DYNAMODB_ENDPOINT=http://localhost:8000

# Cognito Configuration (được set tự động bởi SAM trong production)
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Local Server Configuration
PORT=3001

# Logging
LOG_LEVEL=info
