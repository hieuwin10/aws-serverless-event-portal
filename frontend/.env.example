# Frontend Environment Configuration
# Copy this file to .env for local development or production build

# Backend API URL (use local mock backend or deployed API Gateway URL)
VITE_API_ENDPOINT=http://localhost:3001

# Cognito Configuration (Leave empty to use Mock Auth, fill in when using real AWS Cognito)
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Authentication Mode: "mock" (local simulation) or "cognito" (connect to real AWS Cognito)
VITE_AUTH_MODE=mock

# Data Mode: "true" to force mock local events data, "false" to call database APIs
VITE_USE_MOCK_DATA=true
